<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/client_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.hammami.fragments.client.HomeFragment"
        android:label="HomeFragment"
        tools:layout="@layout/fragment_home">
        <!-- Definisci l'azione di navigazione dal homeFragment al profileFragment -->
        <action
            android:id="@+id/action_homeFragment_to_profileFragment"
            app:destination="@id/navigation_profile" />
        <action
            android:id="@+id/action_homeFragment_to_serviceDetailFragment"
            app:destination="@id/serviceDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.hammami.fragments.client.SearchFragment"
        android:label="SearchFragment"
        tools:layout="@layout/fragment_search" >
        <action
            android:id="@+id/action_searchFragment_to_catalogo_servizi_benessere"
            app:destination="@id/catalogo_servizi_benessere" />
        <action
            android:id="@+id/action_searchFragment_to_catalogo_servizi_estetica"
            app:destination="@id/catalogo_servizi_estetica" />
        <action
            android:id="@+id/action_searchFragment_to_catalogo_servizi_massaggi"
            app:destination="@id/catalogo_servizi_massaggi" />
    </fragment>

    <fragment
        android:id="@+id/aboutUsFragment"
        android:name="com.example.hammami.fragments.client.AboutUsFragment"
        android:label="AboutUsFragment"
        tools:layout="@layout/fragment_appointments" />

    <fragment
        android:id="@+id/appointmentsFragment"
        android:name="com.example.hammami.fragments.client.AppointmentsFragment"
        android:label="AppointmentsFragment"
        tools:layout="@layout/fragment_about_us" />

    <navigation android:id="@+id/navigation_profile"
        app:startDestination="@id/profileFragment">
        <fragment
            android:id="@+id/giftCardsFragment"
            android:name="com.example.hammami.fragments.settings.GiftCardsFragment"
            android:label="GiftCardsFragment"
            tools:layout="@layout/fragment_gift_cards" />
        <fragment
            android:id="@+id/profileFragment"
            android:name="com.example.hammami.fragments.settings.ProfileFragment"
            android:label="Profile"
            tools:layout="@layout/fragment_profile">
            <argument
                android:name="itemProfileOption"
                app:argType="com.example.hammami.models.ItemProfileOption" />
            <action
                android:id="@+id/action_profileFragment_to_giftCardsFragment"
                app:destination="@id/giftCardsFragment" />
        </fragment>
    </navigation>

    <navigation android:id="@+id/catalogo_servizi_benessere"
        app:startDestination="@id/serviziBenessere">
        <fragment
            android:id="@+id/serviziBenessere"
            android:name="com.example.hammami.fragments.categories.BenessereFragment"
            android:label="BenessereFragment"
            tools:layout="@layout/fragment_servizi_benessere" />
        <action
            android:id="@+id/action_global_serviceDetailFragment"
            app:destination="@id/serviceDetailFragment" />
    </navigation>

    <navigation android:id="@+id/catalogo_servizi_estetica"
        app:startDestination="@id/serviziEstetica">
        <fragment
            android:id="@+id/serviziEstetica"
            android:name="com.example.hammami.fragments.categories.EsteticaFragment"
            android:label="EsteticaFragment"
            tools:layout="@layout/fragment_servizi_estetica" />
        <action
            android:id="@+id/action_global_serviceDetailFragment2"
            app:destination="@id/serviceDetailFragment" />
    </navigation>

    <navigation android:id="@+id/catalogo_servizi_massaggi"
        app:startDestination="@id/serviziMassaggi">
        <fragment
            android:id="@+id/serviziMassaggi"
            android:name="com.example.hammami.fragments.categories.MassaggiFragment"
            android:label="MassaggiFragment"
            tools:layout="@layout/fragment_servizi_massaggi" />
        <action
            android:id="@+id/action_global_serviceDetailFragment3"
            app:destination="@id/serviceDetailFragment" />
    </navigation>

    <fragment
        android:id="@+id/serviceDetailFragment"
        android:name="com.example.hammami.fragments.categories.ServiceDetailFragment"
        android:label="ServiceDetailFragment"
        tools:layout="@layout/servizio_dettaglio">
        <argument
            android:name="service"
            app:argType="com.example.hammami.data.Service" />
    </fragment>
    <argument
        android:name="serviceId"
        app:argType="string" />
</navigation>